# User data — ignore contents, keep directory structure
input/*
output/*

# Library — track structure and defaults, ignore user-added content
library/samples/*
library/style-profiles/*

# Keep directory markers
!input/.gitkeep
!output/.gitkeep
!library/**/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Environment
.env
.env.local

# Design docs
senior-legal-review-agent-design.md

# OS
.DS_Store
Thumbs.db
