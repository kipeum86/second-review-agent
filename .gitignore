# User data — ignore contents, keep directory structure
input/*
output/*

# Library — track structure and defaults, ignore user-added content
library/samples/*
library/style-profiles/*
library/inbox/*
library/grade-a/*
library/grade-b/*
library/grade-c/*

# Known Issues generated artifacts
library/known-issues/*.index.json
library/known-issues/occurrence-ledger.jsonl
library/known-issues/frequency-cache.json

# Keep directory markers
!input/.gitkeep
!output/.gitkeep
!library/**/.gitkeep
!library/inbox/_processed/
!library/inbox/_failed/
library/inbox/_processed/*
library/inbox/_failed/*
!library/inbox/_processed/.gitkeep
!library/inbox/_failed/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Environment
.env
.env.local

# Agent-readable private scratch (see docs/plans/security-hardening-codex.md Task 1)
_private/*
!_private/.gitkeep

# citation-auditor test fixtures — confidential opinion files used for audit testing
test-opinion-confidential.md

# OS
.DS_Store
Thumbs.db
